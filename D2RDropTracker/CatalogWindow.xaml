<Window x:Class="D2RDropTracker.CatalogWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="自定义物品词库"
        Width="760" Height="520"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <DataGrid x:Name="CatalogGrid" AutoGenerateColumns="False"
                  CanUserAddRows="True" IsReadOnly="False" AlternationCount="2">
            <DataGrid.Columns>
                <DataGridTextColumn Header="标准名称" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="120"/>
                <DataGridTextColumn Header="品质" Binding="{Binding Quality}" Width="120"/>
                <DataGridTextColumn Header="别名（用 | 分隔）" Binding="{Binding AliasesText}" Width="240"/>
            </DataGrid.Columns>
        </DataGrid>
        <Grid Grid.Row="2">
            <TextBlock Text="自定义词库保存在用户数据目录，程序升级不会覆盖。"
                       Foreground="{StaticResource MutedBrush}" VerticalAlignment="Center"/>
            <Button Content="保存自定义词库" HorizontalAlignment="Right"
                    Click="SaveButton_Click"/>
        </Grid>
    </Grid>
</Window>
