<Window x:Class="D2RDropTracker.BackupWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="备份与恢复"
        Width="700" Height="460"
        MinWidth="620" MinHeight="380"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="14">
            <Grid>
                <TextBlock Text="恢复前会自动保留当前数据库的安全备份。"
                           Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="立即备份" Margin="0,0,10,0" Click="CreateBackupButton_Click"/>
                    <Button Content="打开备份目录" Background="#657382" BorderBrush="#4D5966"
                            Click="OpenFolderButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <DataGrid Grid.Row="2" x:Name="BackupGrid" AutoGenerateColumns="False"
                  SelectionMode="Single" AlternationCount="2">
            <DataGrid.Columns>
                <DataGridTextColumn Header="备份文件" Binding="{Binding FileName}" Width="*"/>
                <DataGridTextColumn Header="创建时间" Binding="{Binding CreatedAtDisplay}" Width="180"/>
                <DataGridTextColumn Header="大小" Binding="{Binding SizeDisplay}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <Grid Grid.Row="4">
            <TextBlock x:Name="StatusTextBlock" Foreground="{StaticResource MutedBrush}"
                       VerticalAlignment="Center"/>
            <Button Content="恢复选中备份" HorizontalAlignment="Right"
                    Background="#C45A55" BorderBrush="#9E3F3A"
                    Click="RestoreButton_Click"/>
        </Grid>
    </Grid>
</Window>
