<Window x:Class="D2RDropTracker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="D2R 掉落统计器" Height="760" Width="1180"
        MinHeight="650" MinWidth="980"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Margin="0,0,14,0">
                    <TextBlock Text="角色" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,5"/>
                    <TextBox x:Name="CharacterTextBox" Text="未命名角色"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="0,0,14,0">
                    <TextBlock Text="难度" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,5"/>
                    <ComboBox x:Name="DifficultyComboBox" SelectedIndex="2">
                        <ComboBoxItem Content="普通"/>
                        <ComboBoxItem Content="噩梦"/>
                        <ComboBoxItem Content="地狱"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="2" Margin="0,0,14,0">
                    <TextBlock Text="刷图目标" Foreground="{StaticResource MutedBrush}" Margin="0,0,0,5"/>
                    <ComboBox x:Name="AreaComboBox" SelectedIndex="0">
                        <ComboBoxItem Content="安达利尔"/>
                        <ComboBoxItem Content="古代通道"/>
                        <ComboBoxItem Content="崔凡克"/>
                        <ComboBoxItem Content="墨菲斯托"/>
                        <ComboBoxItem Content="混沌避难所"/>
                        <ComboBoxItem Content="奶牛关"/>
                        <ComboBoxItem Content="世界之石要塞"/>
                        <ComboBoxItem Content="巴尔"/>
                        <ComboBoxItem Content="其他"/>
                    </ComboBox>
                </StackPanel>
                <StackPanel Grid.Column="3" HorizontalAlignment="Center">
                    <TextBlock Text="本轮用时" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="TimerTextBlock" Text="00:00:00" FontSize="32"
                               FontWeight="Bold" Foreground="{StaticResource GoldBrush}"/>
                    <TextBlock x:Name="CurrentRunStartTextBlock"
                               Text="开始：--"
                               Foreground="{StaticResource MutedBrush}"
                               FontSize="11"
                               HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,10,0">
                    <Button x:Name="StartPauseButton" Content="暂停"
                            Margin="0,0,8,0" Click="StartPauseButton_Click"/>
                    <Button Content="重置本轮"
                            Background="#657382" BorderBrush="#4D5966"
                            Click="ResetRunButton_Click"/>
                </StackPanel>
                <Button Grid.Column="5" x:Name="CompleteRunButton" Content="完成本轮  F8"
                        VerticalAlignment="Center" FontSize="15" Click="CompleteRunButton_Click"/>

                <Grid Grid.Row="2" Grid.ColumnSpan="6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="70"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="玩家人数" VerticalAlignment="Center"/>
                    <ComboBox Grid.Column="1" x:Name="PlayerCountComboBox" SelectedIndex="0">
                        <ComboBoxItem Content="1"/><ComboBoxItem Content="2"/>
                        <ComboBoxItem Content="3"/><ComboBoxItem Content="4"/>
                        <ComboBoxItem Content="5"/><ComboBoxItem Content="6"/>
                        <ComboBoxItem Content="7"/><ComboBoxItem Content="8"/>
                    </ComboBox>
                    <TextBlock Grid.Column="3" Text="MF" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="4" x:Name="MagicFindTextBox" Text="0"/>
                    <TextBlock Grid.Column="6" Text="标签" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="7" x:Name="TagsTextBox" ToolTip="例如：恐怖区域,测试"/>
                    <TextBlock Grid.Column="9" Text="备注" VerticalAlignment="Center"/>
                    <TextBox Grid.Column="10" x:Name="NotesTextBox"/>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="{StaticResource PanelBrush}" CornerRadius="8"
                Padding="12,8" Margin="0,10,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="8"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <CheckBox x:Name="OverlayLockCheckBox"
                          Content="锁定小窗（鼠标穿透）"
                          VerticalAlignment="Center"
                          Foreground="{StaticResource TextBrush}"
                          Checked="OverlayLockCheckBox_Changed"
                          Unchecked="OverlayLockCheckBox_Changed"/>

                <TextBlock Grid.Column="2" Text="完成场次" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="4" x:Name="CompleteHotkeyComboBox"/>
                <TextBlock Grid.Column="6" Text="记录掉落" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="8" x:Name="DropHotkeyComboBox"/>
                <Button Grid.Column="10" Content="应用快捷键" Padding="10,6"
                        Click="ApplyHotkeysButton_Click"/>

                <Button Grid.Column="12" Content="备份恢复" Padding="10,6"
                        Background="#657382" BorderBrush="#4D5966"
                        Click="BackupButton_Click"/>
                <Button Grid.Column="14" Content="场次历史" Padding="10,6"
                        Click="HistoryButton_Click"/>
                <Button Grid.Column="16" Content="撤销上一场" Padding="10,6"
                        Background="#C45A55" BorderBrush="#9E3F3A"
                        Click="UndoLastRunButton_Click"/>
                <Button Grid.Column="18" Content="偏好设置" Padding="10,6"
                        Background="#657382" BorderBrush="#4D5966"
                        Click="PreferencesButton_Click"/>
                <Button Grid.Column="20" Content="截图记录" Padding="10,6"
                        Background="#657382" BorderBrush="#4D5966"
                        Click="ScreenshotButton_Click"/>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="16"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="记录掉落" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                <TextBlock Text="物品名称" Foreground="{StaticResource MutedBrush}"/>
                                <ComboBox x:Name="ItemNameTextBox"
                                          Margin="0,4,0,0"
                                          IsEditable="True"
                                          IsTextSearchEnabled="True"
                                          StaysOpenOnEdit="True"
                                          KeyDown="ItemNameTextBox_KeyDown"
                                          SelectionChanged="ItemNameTextBox_SelectionChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="0,0,10,0">
                                <TextBlock Text="分类" Foreground="{StaticResource MutedBrush}"/>
                                <ComboBox x:Name="CategoryComboBox" Margin="0,4,0,0" SelectedIndex="0">
                                    <ComboBoxItem Content="暗金"/>
                                    <ComboBoxItem Content="套装"/>
                                    <ComboBoxItem Content="符文"/>
                                    <ComboBoxItem Content="底材"/>
                                    <ComboBoxItem Content="珠宝"/>
                                    <ComboBoxItem Content="护符"/>
                                    <ComboBoxItem Content="其他"/>
                                </ComboBox>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Margin="0,0,10,0">
                                <TextBlock Text="品质" Foreground="{StaticResource MutedBrush}"/>
                                <ComboBox x:Name="QualityComboBox" Margin="0,4,0,0" SelectedIndex="0">
                                    <ComboBoxItem Content="暗金"/>
                                    <ComboBoxItem Content="套装"/>
                                    <ComboBoxItem Content="稀有"/>
                                    <ComboBoxItem Content="魔法"/>
                                    <ComboBoxItem Content="普通"/>
                                    <ComboBoxItem Content="符文"/>
                                </ComboBox>
                            </StackPanel>
                            <Button Grid.Column="3" Content="添加掉落" VerticalAlignment="Bottom"
                                    Click="AddDropButton_Click"/>
                        </Grid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="16">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock Text="最近掉落" FontSize="18" FontWeight="SemiBold"/>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button x:Name="UndoDeleteDropButton"
                                        Content="撤销删除"
                                        Padding="10,5"
                                        Margin="0,0,8,0"
                                        IsEnabled="False"
                                        Background="#657382"
                                        BorderBrush="#4D5966"
                                        Click="UndoDeleteDropButton_Click"/>
                                <Button Content="回收站"
                                        Padding="10,5"
                                        Margin="0,0,8,0"
                                        Background="#657382"
                                        BorderBrush="#4D5966"
                                        Click="RecycleBinButton_Click"/>
                                <Button Content="编辑选中" Padding="10,5" Margin="0,0,8,0"
                                        Click="EditDropButton_Click"/>
                                <Button Content="删除选中" Padding="10,5"
                                        Background="#C45A55" Foreground="White"
                                        Click="DeleteDropButton_Click"/>
                            </StackPanel>
                        </Grid>
                        <DataGrid x:Name="RecentDropsGrid" AutoGenerateColumns="False"
                                  SelectionMode="Single" AlternationCount="2"
                                  MouseDoubleClick="RecentDropsGrid_MouseDoubleClick">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="时间" Binding="{Binding DroppedAtDisplay}" Width="120"/>
                                <DataGridTextColumn Header="物品" Binding="{Binding ItemName}" Width="*"/>
                                <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="100"/>
                                <DataGridTextColumn Header="品质" Binding="{Binding Quality}" Width="100"/>
                                <DataGridTextColumn Header="场次" Binding="{Binding RunNumber}" Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>

            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="18">
                    <StackPanel>
                        <TextBlock Text="总览" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,14"/>
                        <UniformGrid Columns="3">
                            <StackPanel>
                                <TextBlock x:Name="TotalRunsTextBlock" Text="0" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource GoldBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="完成场次" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock x:Name="TotalDropsTextBlock" Text="0" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource GoldBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="记录掉落" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel>
                                <TextBlock x:Name="AverageTimeTextBlock" Text="--:--" FontSize="28" FontWeight="Bold"
                                           Foreground="{StaticResource GoldBrush}" HorizontalAlignment="Center"/>
                                <TextBlock Text="平均用时" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="16">
                    <DockPanel>
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock Text="掉落统计" FontSize="18" FontWeight="SemiBold"/>
                            <Button Content="导出 CSV" HorizontalAlignment="Right" Padding="10,5"
                                    Click="ExportCsvButton_Click"/>
                        </Grid>
                        <DataGrid x:Name="DropStatsGrid" AutoGenerateColumns="False" AlternationCount="2">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="物品" Binding="{Binding ItemName}" Width="*"/>
                                <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="80"/>
                                <DataGridTextColumn Header="数量" Binding="{Binding Count}" Width="60"/>
                                <DataGridTextColumn Header="每100场" Binding="{Binding PerHundredRuns, StringFormat={}{0:F2}}" Width="80"/>
                            </DataGrid.Columns>
                        </DataGrid>
                    </DockPanel>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Row="3" Margin="2,12,2,0">
            <TextBlock x:Name="StatusTextBlock" Text="就绪"
                       Foreground="{StaticResource MutedBrush}"/>
            <TextBlock x:Name="HotkeyHintTextBlock"
                       Text="F8 完成本轮  ·  F9 记录掉落" HorizontalAlignment="Right"
                       Foreground="{StaticResource MutedBrush}"/>
        </Grid>
    </Grid>
</Window>
