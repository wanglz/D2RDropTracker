<Window x:Class="D2RDropTracker.ChartsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="统计图表" Width="980" Height="700"
        WindowStartupLocation="CenterOwner">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="近 14 天完成场次" FontSize="18" FontWeight="Bold"/>
            <Canvas x:Name="DailyCanvas" Height="180" Margin="0,8,0,24"
                    Background="{StaticResource PanelBrush}"/>
            <TextBlock Text="区域平均耗时（秒）" FontSize="18" FontWeight="Bold"/>
            <Canvas x:Name="AreaCanvas" Height="220" Margin="0,8,0,24"
                    Background="{StaticResource PanelBrush}"/>
            <TextBlock Text="掉落分类占比" FontSize="18" FontWeight="Bold"/>
            <Canvas x:Name="CategoryCanvas" Height="220" Margin="0,8,0,0"
                    Background="{StaticResource PanelBrush}"/>
        </StackPanel>
    </ScrollViewer>
</Window>
