<Window x:Class="D2RDropTracker.DropEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑掉落"
        Width="560" Height="640"
        MinWidth="520" MinHeight="560"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="物品名称" Foreground="{StaticResource MutedBrush}"/>
                <TextBox x:Name="ItemNameTextBox" Margin="0,5,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="2">
                <TextBlock Text="分类" Foreground="{StaticResource MutedBrush}"/>
                <ComboBox x:Name="CategoryComboBox" Margin="0,5,0,0">
                    <ComboBoxItem Content="暗金"/>
                    <ComboBoxItem Content="套装"/>
                    <ComboBoxItem Content="符文"/>
                    <ComboBoxItem Content="底材"/>
                    <ComboBoxItem Content="珠宝"/>
                    <ComboBoxItem Content="护符"/>
                    <ComboBoxItem Content="其他"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Row="4">
                <TextBlock Text="掉落者" Foreground="{StaticResource MutedBrush}"/>
                <ComboBox x:Name="QualityComboBox" Margin="0,5,0,0">
                    <ComboBoxItem Content="未知"/>
                    <ComboBoxItem Content="普通怪物"/>
                    <ComboBoxItem Content="精英怪"/>
                    <ComboBoxItem Content="箱子"/>
                    <ComboBoxItem Content="女伯爵"/>
                    <ComboBoxItem Content="安达利尔"/>
                    <ComboBoxItem Content="召唤者"/>
                    <ComboBoxItem Content="督瑞尔"/>
                    <ComboBoxItem Content="墨菲斯托"/>
                    <ComboBoxItem Content="暗黑破坏神"/>
                    <ComboBoxItem Content="巴尔"/>
                    <ComboBoxItem Content="尼拉塞克"/>
                    <ComboBoxItem Content="暴躁外皮"/>
                    <ComboBoxItem Content="奶牛"/>
                    <ComboBoxItem Content="其他"/>
                </ComboBox>
            </StackPanel>

            <StackPanel Grid.Row="6">
                <TextBlock Text="交易结果" Foreground="{StaticResource MutedBrush}"/>
                <ComboBox x:Name="TradeTypeComboBox" Margin="0,5,0,0">
                    <ComboBoxItem Content="未处理"/>
                    <ComboBoxItem Content="换符文"/>
                    <ComboBoxItem Content="卖钱"/>
                    <ComboBoxItem Content="自用"/>
                    <ComboBoxItem Content="丢弃"/>
                </ComboBox>
            </StackPanel>

            <Grid Grid.Row="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="换得符文" Foreground="{StaticResource MutedBrush}"/>
                    <TextBox x:Name="TradeRunesTextBox" Margin="0,5,0,0"
                             ToolTip="例如：1 贝 + 2 伊斯特，或 3# + 24#"/>
                </StackPanel>
                <StackPanel Grid.Column="2">
                    <TextBlock Text="卖出金额" Foreground="{StaticResource MutedBrush}"/>
                    <TextBox x:Name="TradeMoneyTextBox" Margin="0,5,0,0"
                             ToolTip="例如：50 元、2.5 USD、游戏币等"/>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="10">
                <TextBlock Text="关联图片" Foreground="{StaticResource MutedBrush}"/>
                <Grid Margin="0,5,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="ScreenshotPathTextBox"/>
                    <Button Grid.Column="2" Content="浏览" Padding="10,6" Click="BrowseScreenshotButton_Click"/>
                    <Button Grid.Column="4" Content="清空" Padding="10,6"
                            Background="#657382" BorderBrush="#4D5966"
                            Click="ClearScreenshotButton_Click"/>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Row="12">
                <TextBlock Text="所属场次" Foreground="{StaticResource MutedBrush}"/>
                <ComboBox x:Name="RunComboBox" Margin="0,5,0,0"
                          DisplayMemberPath="DisplayName" SelectedValuePath="Id"/>
            </StackPanel>

            <StackPanel Grid.Row="14" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Background="#657382" BorderBrush="#4D5966"
                        Margin="0,0,10,0" Click="CancelButton_Click"/>
                <Button Content="保存修改" Click="SaveButton_Click"/>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</Window>
