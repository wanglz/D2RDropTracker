<Window x:Class="D2RDropTracker.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="场次历史与统计"
        Width="1100" Height="650"
        MinWidth="900" MinHeight="520"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="140"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="开始日期" VerticalAlignment="Center"/>
                <DatePicker Grid.Column="1" x:Name="StartDatePicker"/>
                <TextBlock Grid.Column="3" Text="结束日期" VerticalAlignment="Center"/>
                <DatePicker Grid.Column="4" x:Name="EndDatePicker"/>
                <TextBlock Grid.Column="6" Text="角色" VerticalAlignment="Center"/>
                <TextBox Grid.Column="7" x:Name="CharacterFilterTextBox"/>
                <TextBlock Grid.Column="9" Text="区域" VerticalAlignment="Center"/>
                <TextBox Grid.Column="10" x:Name="AreaFilterTextBox"/>
                <TextBlock Grid.Column="12" Text="难度" VerticalAlignment="Center"/>
                <TextBox Grid.Column="13" x:Name="DifficultyFilterTextBox"/>
                <TextBlock Grid.Column="15" Text="标签" VerticalAlignment="Center"/>
                <TextBox Grid.Column="16" x:Name="TagsFilterTextBox"/>
                <Button Grid.Column="18" Content="查询" Padding="16,6" Click="SearchButton_Click"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" CornerRadius="8" Padding="14">
            <UniformGrid Columns="4">
                <StackPanel>
                    <TextBlock x:Name="FilteredRunsTextBlock" Text="0" FontSize="25" FontWeight="Bold"
                               Foreground="{StaticResource GoldBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="筛选场次" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock x:Name="FilteredDropsTextBlock" Text="0" FontSize="25" FontWeight="Bold"
                               Foreground="{StaticResource GoldBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="掉落数量" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock x:Name="FilteredAverageTextBlock" Text="--:--" FontSize="25" FontWeight="Bold"
                               Foreground="{StaticResource GoldBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="平均耗时" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock x:Name="FilteredFastestTextBlock" Text="--:--" FontSize="25" FontWeight="Bold"
                               Foreground="{StaticResource GoldBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="最快耗时" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Center"/>
                </StackPanel>
            </UniformGrid>
        </Border>

        <TabControl Grid.Row="4">
            <TabItem Header="场次记录">
                <DataGrid x:Name="HistoryGrid" AutoGenerateColumns="False"
                          SelectionMode="Single" AlternationCount="2"
                          MouseDoubleClick="HistoryGrid_MouseDoubleClick">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="场次" Binding="{Binding RunNumber}" Width="65"/>
                        <DataGridTextColumn Header="角色" Binding="{Binding Character}" Width="110"/>
                        <DataGridTextColumn Header="区域" Binding="{Binding Area}" Width="130"/>
                        <DataGridTextColumn Header="难度" Binding="{Binding Difficulty}" Width="75"/>
                        <DataGridTextColumn Header="开始时间" Binding="{Binding StartedAtDisplay}" Width="170"/>
                        <DataGridTextColumn Header="结束时间" Binding="{Binding EndedAtDisplay}" Width="170"/>
                        <DataGridTextColumn Header="有效耗时" Binding="{Binding DurationDisplay}" Width="90"/>
                        <DataGridTextColumn Header="掉落数" Binding="{Binding DropCount}" Width="75"/>
                        <DataGridTextColumn Header="人数" Binding="{Binding PlayerCount}" Width="60"/>
                        <DataGridTextColumn Header="MF" Binding="{Binding MagicFind}" Width="65"/>
                        <DataGridTextColumn Header="标签" Binding="{Binding Tags}" Width="130"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="筛选掉落统计">
                <DataGrid x:Name="FilteredDropStatsGrid" AutoGenerateColumns="False"
                          AlternationCount="2">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="物品" Binding="{Binding ItemName}" Width="*"/>
                        <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="140"/>
                        <DataGridTextColumn Header="数量" Binding="{Binding Count}" Width="100"/>
                        <DataGridTextColumn Header="每100场" Binding="{Binding PerHundredRuns, StringFormat={}{0:F2}}" Width="120"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <Grid Grid.Row="6">
            <StackPanel Orientation="Horizontal">
                <Button Content="编辑选中场次" Margin="0,0,10,0"
                        Click="EditRunButton_Click"/>
                <Button Content="删除选中场次" Background="#C45A55" BorderBrush="#9E3F3A"
                        Click="DeleteRunButton_Click"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="统计图表" Margin="0,0,10,0" Click="ChartsButton_Click"/>
                <Button Content="清除筛选" Background="#657382" BorderBrush="#4D5966"
                        Margin="0,0,10,0" Click="ClearFilterButton_Click"/>
                <Button Content="导出场次 CSV" Click="ExportButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
