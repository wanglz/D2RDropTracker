<Window x:Class="D2RDropTracker.RecycleBinWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="掉落回收站"
        Width="820" Height="500"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <DataGrid x:Name="DeletedDropsGrid" AutoGenerateColumns="False"
                  SelectionMode="Single" AlternationCount="2">
            <DataGrid.Columns>
                <DataGridTextColumn Header="删除时间" Binding="{Binding DeletedAtDisplay}" Width="170"/>
                <DataGridTextColumn Header="物品" Binding="{Binding ItemName}" Width="*"/>
                <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="100"/>
                <DataGridTextColumn Header="品质" Binding="{Binding Quality}" Width="100"/>
                <DataGridTextColumn Header="原场次" Binding="{Binding RunNumber}" Width="80"/>
            </DataGrid.Columns>
        </DataGrid>
        <Grid Grid.Row="2">
            <Button Content="清空回收站" Background="#C45A55" BorderBrush="#9E3F3A"
                    Click="EmptyButton_Click"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="永久删除" Background="#657382" BorderBrush="#4D5966"
                        Margin="0,0,10,0" Click="DeleteButton_Click"/>
                <Button Content="恢复选中" Click="RestoreButton_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
