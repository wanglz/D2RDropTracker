<Window x:Class="D2RDropTracker.PreferencesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="偏好设置"
        Width="620" Height="640"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="12"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <GroupBox Header="组合快捷键" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="180"/>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="120"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="完成场次" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" x:Name="CompleteModifierComboBox"/>
                <ComboBox Grid.Column="3" x:Name="CompleteKeyComboBox"/>

                <TextBlock Grid.Row="2" Text="记录掉落" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="2" Grid.Column="1" x:Name="DropModifierComboBox"/>
                <ComboBox Grid.Row="2" Grid.Column="3" x:Name="DropKeyComboBox"/>

                <TextBlock Grid.Row="4" Text="显示/隐藏小窗" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="OverlayModifierComboBox"/>
                <ComboBox Grid.Row="4" Grid.Column="3" x:Name="OverlayKeyComboBox"/>

                <TextBlock Grid.Row="6" Text="保存截图" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="6" Grid.Column="1" x:Name="ScreenshotModifierComboBox"/>
                <ComboBox Grid.Row="6" Grid.Column="3" x:Name="ScreenshotKeyComboBox"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="2" Header="监控小窗" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="70"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="12"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="透明度" VerticalAlignment="Center"/>
                <Slider Grid.Column="1" x:Name="OpacitySlider" Minimum="0.35" Maximum="1"
                        SmallChange="0.05" LargeChange="0.1" TickFrequency="0.05"
                        IsSnapToTickEnabled="True"/>
                <TextBlock Grid.Column="2" x:Name="OpacityValueTextBlock"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="2" Text="整体缩放" VerticalAlignment="Center"/>
                <Slider Grid.Row="2" Grid.Column="1" x:Name="ScaleSlider"
                        Minimum="0.75" Maximum="1.5" TickFrequency="0.05"
                        IsSnapToTickEnabled="True"/>
                <TextBlock Grid.Row="2" Grid.Column="2" x:Name="ScaleValueTextBlock"
                           HorizontalAlignment="Right" VerticalAlignment="Center"/>

                <TextBlock Grid.Row="4" Text="最近掉落条数" VerticalAlignment="Center"/>
                <ComboBox Grid.Row="4" Grid.Column="1" x:Name="DropCountComboBox"
                          HorizontalAlignment="Left" Width="100"/>
            </Grid>
        </GroupBox>

        <GroupBox Grid.Row="4" Header="数据维护" Padding="12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="备份保留天数" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="RetentionDaysTextBox"/>
                <TextBlock Grid.Column="2" Text="（最少 1 天）"
                           Margin="10,0,0,0" Foreground="{StaticResource MutedBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button Content="管理物品词库" Margin="0,0,10,0"
                            Click="CatalogButton_Click"/>
                    <Button Content="检查数据库" Click="CheckDatabaseButton_Click"/>
                </StackPanel>
            </Grid>
        </GroupBox>

        <TextBlock Grid.Row="5" x:Name="StatusTextBlock"
                   Foreground="{StaticResource MutedBrush}" Margin="0,14,0,0"/>

        <StackPanel Grid.Row="6" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Background="#657382" BorderBrush="#4D5966"
                    Margin="0,0,10,0" Click="CancelButton_Click"/>
            <Button Content="保存设置" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
