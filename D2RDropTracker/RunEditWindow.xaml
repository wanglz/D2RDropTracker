<Window x:Class="D2RDropTracker.RunEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="编辑场次"
        Width="620" Height="650"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="角色" Foreground="{StaticResource MutedBrush}"/>
        <TextBox Grid.Row="2" x:Name="CharacterTextBox"/>
        <TextBlock Grid.Row="4" Text="区域" Foreground="{StaticResource MutedBrush}"/>
        <TextBox Grid.Row="6" x:Name="AreaTextBox"/>
        <TextBlock Grid.Row="8" Text="难度" Foreground="{StaticResource MutedBrush}"/>
        <ComboBox Grid.Row="10" x:Name="DifficultyComboBox">
            <ComboBoxItem Content="普通"/>
            <ComboBoxItem Content="噩梦"/>
            <ComboBoxItem Content="地狱"/>
        </ComboBox>
        <Grid Grid.Row="11" Margin="0,14,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="开始时间（yyyy-MM-dd HH:mm:ss）"
                           Foreground="{StaticResource MutedBrush}"/>
                <TextBox x:Name="StartedAtTextBox" Margin="0,5,0,0"/>
            </StackPanel>
            <StackPanel Grid.Column="2">
                <TextBlock Text="结束时间（yyyy-MM-dd HH:mm:ss）"
                           Foreground="{StaticResource MutedBrush}"/>
                <TextBox x:Name="EndedAtTextBox" Margin="0,5,0,0"/>
            </StackPanel>
        </Grid>
        <TextBlock Grid.Row="13" Text="玩家人数 / MF" Foreground="{StaticResource MutedBrush}"/>
        <Grid Grid.Row="14">
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="12"/><ColumnDefinition/></Grid.ColumnDefinitions>
            <ComboBox x:Name="PlayerCountComboBox"/>
            <TextBox Grid.Column="2" x:Name="MagicFindTextBox"/>
        </Grid>
        <TextBlock Grid.Row="15" Text="标签" Foreground="{StaticResource MutedBrush}"/>
        <TextBox Grid.Row="16" x:Name="TagsTextBox"/>
        <TextBlock Grid.Row="17" Text="备注" Foreground="{StaticResource MutedBrush}"/>
        <TextBox Grid.Row="18" x:Name="NotesTextBox" Height="55" AcceptsReturn="True"/>
        <StackPanel Grid.Row="20" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="取消" Background="#657382" BorderBrush="#4D5966"
                    Margin="0,0,10,0" Click="CancelButton_Click"/>
            <Button Content="保存修改" Click="SaveButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
